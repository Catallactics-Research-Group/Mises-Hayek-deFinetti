	abstract = {Diffusion models have recently emerged as powerful learners for simulation-based inference (SBI), enabling fast and accurate estimation of latent parameters from simulated and real data. Their scorebased formulation offers a flexible way to learn conditional or joint distributions over parameters and observations, thereby providing a versatile solution to various modeling problems. In this tutorial review, we synthesize recent developments on diffusion models for SBI, covering design choices for training, inference, and evaluation. We highlight opportunities created by various concepts such as guidance, score composition, flow matching, consistency models, and joint modeling. Furthermore, we discuss how efficiency and statistical accuracy are affected by noise schedules, parameterizations, and samplers. Finally, we illustrate these concepts with case studies across parameter dimensionalities, simulation budgets, and model types, and outline open questions for future research.},
	language = {en},
	urldate = {2026-05-20},
	publisher = {arXiv},
	author = {Arruda, Jonas and Bracher, Niels and Köthe, Ullrich and Hasenauer, Jan and Radev, Stefan T.},
	month = jan,
	year = {2026},
	note = {arXiv:2512.20685 [stat.ML]},
	keywords = {Statistics - Methodology, Statistics - Machine Learning, Computer Science - Machine Learning},
	file = {PDF:/Users/a00714634/Zotero/storage/8YUK4TNK/Arruda et al. - 2026 - Diffusion Models in Simulation-Based Inference A Tutorial Review.pdf:application/pdf},
}

