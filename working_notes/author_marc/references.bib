
@article{hill_bayesian_1994,
	title = {Bayesian {Forecasting} of {Economic} {Time} {Series}},
	volume = {10},
	copyright = {https://www.cambridge.org/core/terms},
	issn = {0266-4666, 1469-4360},
	url = {https://www.cambridge.org/core/product/identifier/S0266466600008641/type/journal_article},
	doi = {10.1017/s0266466600008641},
	abstract = {A model is suggested to forecast economic time series. This model incorporates some innovative ideas of Harrison and Stevens [20] for building into the forecasting process important external shocks to the systems. Thus the occurrence of possibly significant real-world events may cause a fundamental change in the time series in question. The Jeffreys-Savage (JS) Bayesian theory of hypothesis testing is used to test the hypothesis that a particular event has been such as to free the series from its immediate past behavior. When the event frees the series in this way, then we model the sequence of observations following such an event (until the next such event) as an exchangeable sequence. In the simplest case of 0–1 valued data, such as in recording the ups and downs of the value of a particular commodity or stock, our alternative hypothesis is a Pólya process, and the null hypothesis is a simple random walk (unit roots model) withp= .50. Any exchangeable sequence is strictly stationary, and the observations in the Polya process are positively correlated, which can give rise to “explosive” behavior of the series at isolated time points. We then use the JS theory to predict future observations by taking a weighted average of the optimal predictions for each model, with weights given by the posterior probabilities of the hypotheses. Results of simulation studies are presented which compare the predictive performance of the fully Bayesian method based upon the JS theory with those based upon the “p-value” or pre-test method. The de Finetti method for scoring predictions is used to assess their empirical performance. A theoretical methodology, which extends the “evaluation game” of Hill [28,37], is developed for comparing predictors.},
	language = {en},
	number = {3-4},
	urldate = {2025-05-23},
	journal = {Econometric Theory},
	publisher = {Cambridge University Press (CUP)},
	author = {Hill, Bruce M.},
	month = aug,
	year = {1994},
	keywords = {de Finetti, Bayesian},
	pages = {483--513},
	annote = {From Tyler: “I first came upon him in my preliminary look into the finite vs countable question, on which he has very definite views that side with de Finetti. I had seen him referenced before but never followed the links beyond what I was reading at the time. I think his views are compelling and worthy of consideration. They are very nuanced. 
But for more immediate purposes I want to talk about the very creative approach in the attached paper. He kind of blows my mind in this paper. He shows me how my thinking is still very much circumscribed by the mainstream approach. In this paper he takes a pretty astonishing departure from the Wold framework for stochastic processes. I find it very tantalizing for modeling evolutionary economic processes. The paper is very frustrating in one regard though: I find it very vague in some parts. I think must believe that his reader is sympathetic to his way of thinking and so he doesn't feel the need for certain details that would have helped me very much indeed. I wish he had been a bit more pedantic. That's a lesson for us as we translate this kind of intuitive work which is often stems from the more subjectivist perspective. 
Of particular note is his exchangeable model of price sign change. He states that he could model price change itself which has me thinking about how to do that. Also of note is his very creative data analysis and hypothesis testing approach. All of this is very much from a prediction and decision making perspective. 
At any rate, I think this is one we can very much learn from, especially about how to model "creatively." Given the entrepreneurial or "creative arbitrage" microfoundations from which we are building this is at the heart of our project. “
Tyler says the "evaluation game” might be very much relevant to thinking about conjoint ensembles.
},
	file = {PDF:/Users/a00714634/Zotero/storage/EXF2ZR94/Hill - 1994 - Bayesian Forecasting of Economic Time Series.pdf:application/pdf},
}

