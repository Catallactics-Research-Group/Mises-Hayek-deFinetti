@article{robinson_how_2024,
	title = {How to {Detect} {Heterogeneity} in {Conjoint} {Experiments}},
	volume = {86},
	issn = {0022-3816, 1468-2508},
	url = {https://www.journals.uchicago.edu/doi/10.1086/727597},
	doi = {10.1086/727597},
	abstract = {Conjoint experiments are fast becoming one of the dominant experimental methods within the social sciences. Despite recent efforts to model heterogeneity within this type of experiment, the relationship between the conjoint design and lower-level causal estimands is underdeveloped. In this paper, we clarify how conjoint heterogeneity can be construed as a set of nested, causal parameters that correspond to the levels of the conjoint design. We then use this framework to propose a new estimation strategy, using machine learning, that better allows researchers to evaluate treatment effect heterogeneity. We also provide novel tools for classifying and analysing heterogeneity post-estimation using partitioning algorithms. Replicating two conjoint experiments, we demonstrate our theoretical argument, and show how this method helps estimate and detect substantive patterns of heterogeneity. To accompany this paper, we provide new a R package, cjbart, that allows researchers to model heterogeneity in their experimental conjoint data.},
	language = {en},
	number = {2},
	urldate = {2025-07-24},
	journal = {The Journal of Politics},
	publisher = {University of Chicago Press},
	author = {Robinson, Thomas S. and Duch, Raymond M.},
	month = apr,
	year = {2024},
	pages = {412--427},
	file = {PDF:/Users/a00714634/Zotero/storage/JEDPL2GM/Robinson and Duch - 2024 - How to Detect Heterogeneity in Conjoint Experiments.pdf:application/pdf},
}

@misc{kane_being_2024,
	title = {Being {Careful} with {Conjoints}: {Accounting} for {Inattentiveness} in {Conjoint} {Experiments}},
	copyright = {https://preprints.apsanet.org/engage/apsa/legal-information?show=terms-of-use},
	shorttitle = {Being {Careful} with {Conjoints}},
	url = {https://preprints.apsanet.org/engage/apsa/article-details/670976e851558a15efcd1ea5},
	doi = {10.33774/apsa-2024-xqt7d},
	abstract = {In typical survey experiments–i.e., experiments that involve a relatively limited amount of manipulated content–respondent inattentiveness tends to biase treatment effect estimates toward zero. Such bias may be even more pronounced in conjoint experiments, which require respondents to attend to an even larger amount of manipulated content. And yet, little research has investigated strategies of accounting for inattentiveness in conjoint experiments specifically. In this study, we explore potential ways to both measure–and account for–respondent inattentiveness when estimating causal effects in both single- and two-profile conjoint experiments. Replicating published conjoint experiments with large national samples, we demonstrate how researchers can implement a simple strategy using pre-treatment measures of attentiveness. Toward this end, we propose a novel method– “conjoint attention checks” (CACs)–to both measure respondents’ attentiveness to conjoint profiles and to provide for more robust tests of hypotheses in conjoint experiments.},
	language = {en},
	urldate = {2025-07-24},
	publisher = {Cambridge University Press (CUP)},
	author = {Kane, John V. and Costa, Mia},
	month = oct,
	year = {2024},
	file = {PDF:/Users/a00714634/Zotero/storage/ZKKVXN8H/Kane and Costa - 2024 - Being Careful with Conjoints Accounting for Inattentiveness in Conjoint Experiments.pdf:application/pdf},
}

@article{papamakarios_normalizing_nodate,
	title = {Normalizing {Flows} for {Probabilistic} {Modeling} and {Inference}},
	abstract = {Normalizing ﬂows provide a general mechanism for deﬁning expressive probability distributions, only requiring the speciﬁcation of a (usually simple) base distribution and a series of bijective transformations. There has been much recent work on normalizing ﬂows, ranging from improving their expressive power to expanding their application. We believe the ﬁeld has now matured and is in need of a uniﬁed perspective. In this review, we attempt to provide such a perspective by describing ﬂows through the lens of probabilistic modeling and inference. We place special emphasis on the fundamental principles of ﬂow design, and discuss foundational topics such as expressive power and computational trade-oﬀs. We also broaden the conceptual framing of ﬂows by relating them to more general probability transformations. Lastly, we summarize the use of ﬂows for tasks such as generative modeling, approximate inference, and supervised learning.},
	language = {en},
	author = {Papamakarios, George and Nalisnick, Eric and Rezende, Danilo Jimenez and Mohamed, Shakir and Lakshminarayanan, Balaji},
