@article{dotson_randomization_nodate,
	title = {Randomization and {Ensembling} {Strategies} for {Accommodating} {Multiple} {Data} {Pathologies} in {Conjoint} {Studies}},
	abstract = {Conjoint analysis is a widely used methodology in marketing research, grounded in random utility theory and assumptions of utility maximization. However, consumer choice behavior frequently deviates from these assumptions, exhibiting various data pathologies that challenge standard modeling approaches. These pathologies include non-compensatory decision-making, attribute non-attendance, screening rules, and heuristic-driven choices that violate traditional hierarchical Bayesian multinomial logit (HB-MNL) assumptions. While prior research has addressed individual pathologies through specialized statistical models, these approaches are often computationally intensive, difficult to estimate, and rarely adopted in practice due to their complexity. This paper introduces a novel computational framework leveraging model ensembling techniques to address multiple data pathologies simultaneously without requiring complex model specifications. By constructing simplified models that represent specific pathologies and combining them through stacking ensemble methods, we integrate across a behavioral choice space to yield more accurate out-of-sample predictions while reducing specification complexity. Our approach shifts the tradeoff from model complexity to computational intensity, emphasizing the generation and integration of multiple simple models rather than the development of singular, complex ones. Through simulation studies and an empirical application, we demonstrate that our ensemble approach matches or exceeds the performance of specialized models while providing insights into the heterogeneity of decision processes. This framework offers both methodological contributions to choice modeling and practical benefits for marketing researchers seeking more robust predictions of consumer behavior.},
	language = {en},
	author = {Dotson, Marc R and Bailey, Roger and Dotson, Jeffrey P},
	file = {PDF:/Users/a00714634/Zotero/storage/W8HS6ZTC/Dotson et al. - Randomization and Ensembling Strategies for Accommodating Multiple Data Pathologies in Conjoint Stud.pdf:application/pdf},
}

@article{talts_validating_nodate,
	title = {Validating {Bayesian} {Inference} {Algorithms} with {Simulation}-{Based} {Calibration}},
	abstract = {Verifying the correctness of Bayesian computation is challenging. This is especially true for complex models that are common in practice, as these require sophisticated model implementations and algorithms. In this paper we introduce simulation-based calibration (SBC), a general procedure for validating inferences from Bayesian algorithms capable of generating posterior samples. This procedure not only identiﬁes inaccurate computation and inconsistencies in model implementations but also provides graphical summaries that can indicate the nature of the problems that arise. We argue that SBC is a critical part of a robust Bayesian workﬂow, as well as being a useful tool for those developing computational algorithms and statistical software.},
	language = {en},
	author = {Talts, Sean and Betancourt, Michael and Simpson, Daniel and Vehtari, Aki and Gelman, Andrew},
	file = {PDF:/Users/a00714634/Zotero/storage/Q24CUSBW/Talts et al. - Validating Bayesian Inference Algorithms with Simulation-Based Calibration.pdf:application/pdf},
}

@article{yao_yes_nodate,
